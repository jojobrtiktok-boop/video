# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Porta do servidor (padrão 3000)
PORT=3000

# Chave da OpenAI — necessária apenas para o modo "Transcrever"
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Caminho do ffmpeg — deixe vazio para usar o padrão do sistema (Linux: 'ffmpeg', Windows: auto)
# FFMPEG_BIN=/usr/bin/ffmpeg
